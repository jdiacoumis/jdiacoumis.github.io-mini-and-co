{
  "name": "miniandco-booking",
  "private": true,
  "type": "module",
  "description": "In-house booking system for Mini & Co. Sensory Classes — Cloudflare Worker + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply miniandco-booking --local",
    "migrate:remote": "wrangler d1 migrations apply miniandco-booking --remote",
    "seed:local": "wrangler d1 execute miniandco-booking --local --file=seed/dev-seed.sql",
    "test": "node --test test/unit/",
    "e2e": "node test/e2e/run.js"
  },
  "devDependencies": {
    "wrangler": "^4.86.0"
  }
}
